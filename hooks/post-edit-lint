#!/usr/bin/env python3
"""PostToolUse hook: run linter on edited file, report new warnings to Claude."""

import ast
import json
import os
import subprocess
import sys
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:
    tomllib = None


def find_project_root(file_path):
    """Walk up from file_path to find project root and detect language."""
    p = Path(file_path).resolve()
    for parent in [p.parent] + list(p.parent.parents):
        if (parent / "Cargo.toml").exists():
            return parent, "rust"
        if (parent / "pyproject.toml").exists() or (parent / "setup.py").exists():
            return parent, "python"
        if (parent / "go.mod").exists():
            return parent, "go"
        if (parent / "package.json").exists():
            return parent, "node"
    return None, None


def run(cmd, cwd, timeout=30):
    try:
        result = subprocess.run(
            cmd,
            shell=False,
            cwd=str(cwd),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=timeout,
        )
    except FileNotFoundError:
        return 127, ""
    return result.returncode, (result.stdout or "").strip()


def load_cargo_manifest(manifest_path):
    try:
        if tomllib is not None:
            with manifest_path.open("rb") as f:
                return tomllib.load(f)

        current_section = None
        pending_key = None
        pending_value_lines = []
        manifest = {}

        def store_value(section, key, value):
            if section not in ("package", "workspace"):
                return

            parsed = ast.literal_eval(value)
            if section == "package" and key == "name" and isinstance(parsed, str):
                manifest.setdefault("package", {})["name"] = parsed
            elif (
                section == "workspace"
                and key == "members"
                and isinstance(parsed, list)
            ):
                members = [member for member in parsed if isinstance(member, str)]
                manifest.setdefault("workspace", {})["members"] = members

        for raw_line in manifest_path.read_text().splitlines():
            line = raw_line.split("#", 1)[0].strip()
            if not line:
                continue

            if pending_key:
                pending_value_lines.append(line)
                if line.endswith("]"):
                    store_value(
                        current_section,
                        pending_key,
                        " ".join(pending_value_lines),
                    )
                    pending_key = None
                    pending_value_lines = []
                continue

            if line.startswith("[") and line.endswith("]"):
                current_section = line[1:-1].strip()
                continue

            if "=" not in line or not current_section:
                continue

            key, value = [part.strip() for part in line.split("=", 1)]
            if (
                current_section == "workspace"
                and key == "members"
                and value.startswith("[")
                and not value.endswith("]")
            ):
                pending_key = key
                pending_value_lines = [value]
                continue

            store_value(current_section, key, value)

        return manifest
    except Exception:
        return {}


def cargo_package_name(manifest):
    package = manifest.get("package")
    if not isinstance(package, dict):
        return None

    name = package.get("name")
    if isinstance(name, str) and name:
        return name
    return None


def workspace_member_manifests(workspace_root, manifest):
    workspace = manifest.get("workspace")
    if not isinstance(workspace, dict):
        return []

    members = workspace.get("members")
    if not isinstance(members, list):
        return []

    manifests = []
    for member in members:
        if not isinstance(member, str):
            continue
        for member_dir in sorted(workspace_root.glob(member)):
            member_manifest = member_dir / "Cargo.toml"
            if member_manifest.exists():
                manifests.append(member_manifest)
    return manifests


def cargo_clippy_cmd(file_path):
    rust_file = Path(file_path).resolve()

    for parent in [rust_file.parent] + list(rust_file.parent.parents):
        manifest_path = parent / "Cargo.toml"
        if not manifest_path.exists():
            continue

        manifest = load_cargo_manifest(manifest_path)
        package_name = cargo_package_name(manifest)
        if package_name:
            return ["cargo", "clippy", "-p", package_name]

        if not isinstance(manifest.get("workspace"), dict):
            continue

        for member_manifest in workspace_member_manifests(parent, manifest):
            try:
                rust_file.relative_to(member_manifest.parent.resolve())
            except ValueError:
                continue

            member_name = cargo_package_name(load_cargo_manifest(member_manifest))
            if member_name:
                return ["cargo", "clippy", "-p", member_name]

        return None

    return None


def main():
    try:
        data = json.load(sys.stdin)
    except Exception:
        sys.exit(0)

    tool_name = data.get("tool_name", "")
    tool_input = data.get("tool_input", {})

    if tool_name not in ("Edit", "Write", "MultiEdit"):
        sys.exit(0)

    file_path = tool_input.get("file_path", "")
    if not file_path or not os.path.exists(file_path):
        sys.exit(0)

    project_root, lang = find_project_root(file_path)
    if not project_root or not lang:
        sys.exit(0)

    rel = os.path.relpath(file_path, project_root)
    messages = []

    try:
        if lang == "rust":
            # Auto-format in place (silent)
            run(["cargo", "fmt", "--", rel], project_root)
            # Scope cargo clippy via -p <pkg>; skip virtual-workspace-root orphans.
            clippy_cmd = cargo_clippy_cmd(file_path)
            if clippy_cmd:
                _, out = run(clippy_cmd, project_root)
                if out:
                    relevant = [
                        line
                        for line in out.splitlines()
                        if rel in line
                        or line.strip().startswith("error")
                        or line.strip().startswith("warning")
                    ]
                    relevant = relevant[:30]
                    if relevant:
                        messages.append("cargo clippy:\n" + "\n".join(relevant))

        elif lang == "python":
            # Detect formatter
            has_ruff = run(["ruff", "--version"], project_root)[0] == 0
            has_black = run(["black", "--version"], project_root)[0] == 0

            if has_ruff:
                run(["ruff", "format", rel], project_root)
                rc, out = run(["ruff", "check", rel], project_root)
            elif has_black:
                run(["black", rel], project_root)
                rc, out = run(["flake8", rel], project_root)
            else:
                sys.exit(0)

            if rc != 0 and out:
                messages.append("Linter:\n" + out[:800])

        elif lang == "go":
            run(["gofmt", "-w", rel], project_root)
            rc, out = run(["go", "vet", "./..."], project_root)
            if rc != 0 and out:
                relevant = [line for line in out.splitlines() if rel in line]
                if relevant:
                    messages.append("go vet:\n" + "\n".join(relevant[:20]))

        elif lang == "node":
            try:
                pkg = json.loads((project_root / "package.json").read_text())
            except Exception:
                sys.exit(0)
            all_deps = {**pkg.get("devDependencies", {}), **pkg.get("dependencies", {})}

            if "prettier" in all_deps:
                run(["npx", "prettier", "--write", rel], project_root)
            if "eslint" in all_deps:
                rc, out = run(["npx", "eslint", rel], project_root)
                if rc != 0 and out:
                    messages.append("ESLint:\n" + out[:800])

    except subprocess.TimeoutExpired:
        sys.exit(0)
    except Exception:
        sys.exit(0)

    if messages:
        msg = f"Linter ({lang}) — {rel}:\n\n" + "\n\n".join(messages)
        print(json.dumps({"systemMessage": msg}))

    sys.exit(0)


if __name__ == "__main__":
    main()
