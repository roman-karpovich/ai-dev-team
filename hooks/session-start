#!/usr/bin/env bash
# SessionStart hook for ai-dev-team plugin
# Injects workflow orientation into Claude Code sessions with ai-dev-team signals.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

detect_ai_dev_team_signal() {
    shopt -u nullglob failglob 2>/dev/null || true
    if [ -f ".ai-dev-team.yml" ] || [ -f ".ai-dev-team.local.yml" ]; then
        return 0
    fi

    if [ -n "${HOME:-}" ]; then
        local sanitized_cwd
        sanitized_cwd="${PWD//\//-}"
        if compgen -G "${HOME}/.claude/projects/${sanitized_cwd}/memory/reference_kb_*.md" >/dev/null 2>&1; then
            return 0
        fi
    fi

    if [ -f "CLAUDE.md" ] && grep -q -e 'ai-dev-team' -e '/feature' -e '/cross-audit' CLAUDE.md; then
        return 0
    fi

    return 1
}

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Output context injection as JSON.
# Claude Code sets CLAUDE_PLUGIN_ROOT — emit hookSpecificOutput format.
# Cursor sets CURSOR_PLUGIN_ROOT — emit additional_context format.
# Others / Copilot CLI — emit additionalContext (SDK standard).
if detect_ai_dev_team_signal; then
  session_context_raw=$(cat "${SCRIPT_DIR}/session-prompt.md")
  session_context=$(escape_for_json "$session_context_raw")
  if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
  elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
  else
    printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
  fi
else
  printf '{}\n'
fi

exit 0
