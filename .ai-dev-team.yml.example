# AI Dev Team Plugin — project configuration
# Copy/adapt this template to create .ai-dev-team.yml in your project root.
# Commit .ai-dev-team.yml for team-shared config.
# Keep .ai-dev-team.local.yml in your .gitignore for personal path overrides.

# Required: absolute path to your team's knowledge base
kb_path: <set-me>

# Optional: project name override (defaults to basename of repo directory)
# project: my-project-name

# Optional: project_type gates the security R-rule cluster (R9-R14 today) during
# /feature code-audit. Allowlist values: smart_contract | backend | frontend | data_pipeline.
# Resolution chain: spec frontmatter `project_type:` → .ai-dev-team.local.yml → .ai-dev-team.yml → None.
# When unresolved, the cross-auditor emits a degraded warning at audit time and
# normalizes the active filter to "all" per code-quality-rules.md §Taxonomy Trigger A.
# project_type: backend

# Optional: Codex MCP overrides — apply to developer-codex and cross-auditor
# when they invoke `mcp__codex__codex`. Both fields are optional.
# codex:
#   model: gpt-5.6-sol        # omit to use ~/.codex/config.toml default (recommended — single global model config)
#   reasoning_effort: xhigh   # one of minimal|low|medium|high|xhigh (default: xhigh)

# Optional: Cross-audit probe kill-switch — spec 2026-04-21-cross-audit-probes-foundation §3.4.
# Each probe has a four-mode switch: off|shadow|warn|block. Every probe defaults to
# `off` when `cross_audit.probes` is absent or a given probe id is missing. Probe ids
# are a forward-looking enum; unknown ids emit a one-line warning (not a hard-stop).
# Foundation ships the parser + validator; probes E, F, G arrive in follow-up specs.
# cross_audit:
#   probes:
#     e: { mode: off }      # E = diff-scope leak detector (same-file Python allowlist, spec
#                           # 2026-04-21-probe-e-diff-scope-leak); set `mode: shadow` to start
#                           # collecting live evidence toward graduation.
#     f: { mode: off }      # F = cardinality blindness (same-file missing-cursor,
#                           # spec 2026-04-21-probe-f-cardinality-blindness) — set to
#                           # `shadow` to start collecting live evidence toward
#                           # graduation. Detects added paging-method calls
#                           # (e.g. `.limit(...)`, `.paginate(...)`) in functions
#                           # lacking cursor-discipline parameters or cardinality
#                           # docstring keywords.
#     g: { mode: off }      # G = test-set redundancy detector (follow-up spec)
