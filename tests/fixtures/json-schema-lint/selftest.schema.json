{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Self-test schema for tests/lib/json_schema_lint.py. Exercises every supported keyword: type, required, properties, items, enum, additionalProperties.",
  "type": "object",
  "required": ["name", "severity", "tags"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "severity": { "type": "string", "enum": ["HIGH", "LOW"] },
    "count": { "type": "integer" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
