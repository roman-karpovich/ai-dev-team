{
  "spec_version": "adr1-v2",
  "source_adr": "v2 VERIFY ADR-1 (state machine and snapshot); this JSON is the pinned encoding — on divergence the ADR wins",
  "phases": ["CREATED", "SNAPSHOT_BOUND", "PLAN_BOUND", "EXECUTING", "CONSOLIDATING", "ADJUDICATING"],
  "terminals": ["COMPLETED", "INCOMPLETE", "FAILED", "BLOCKED", "CANCELLED"],
  "release_recommendations": ["PROCEED", "HOLD", "REPORT_ONLY"],
  "run_transitions": [
    {"id": "R0", "from": "CREATED", "event": "intent_blocked", "to": "BLOCKED", "guards": []},
    {"id": "R1", "from": "CREATED", "event": "snapshot_sealed", "to": "SNAPSHOT_BOUND", "guards": []},
    {"id": "R2", "from": "CREATED", "event": "snapshot_blocked", "to": "BLOCKED", "guards": []},
    {"id": "R3", "from": "SNAPSHOT_BOUND", "event": "plan_resolved", "to": "PLAN_BOUND", "guards": []},
    {"id": "R4", "from": "SNAPSHOT_BOUND", "event": "plan_blocked", "to": "BLOCKED", "guards": []},
    {"id": "R5", "from": "PLAN_BOUND", "event": "execution_started", "to": "EXECUTING", "guards": []},
    {"id": "R6", "from": "EXECUTING", "event": "derived:all_required_nodes_settled", "to": "CONSOLIDATING", "guards": ["G_EXEC_SETTLED"]},
    {"id": "R7", "from": "CONSOLIDATING", "event": "derived:consolidation_complete", "to": "ADJUDICATING", "guards": []},
    {"id": "R8", "from": "ADJUDICATING", "event": "derived:adjudication_settled", "to": "@terminal_decision", "guards": ["G_ADJ_SETTLED"]},
    {"id": "R9", "from": "@any_nonterminal", "event": "cancel_requested", "to": "@same", "guards": []},
    {"id": "R9b", "from": "@any_nonterminal", "event": "budget_exhausted", "to": "@same", "guards": []},
    {"id": "R10", "from": "@any_nonterminal", "event": "cancel_finalized", "to": "CANCELLED", "guards": ["G_CANCEL_FINAL"]},
    {"id": "R11", "from": "@any", "event": "corruption_detected", "to": "FAILED", "guards": []}
  ],
  "attempt_states": ["SCHEDULED", "DISPATCHED", "COMPLETED", "FAILED", "CANCELLED", "ABANDONED"],
  "attempt_settled_states": ["COMPLETED", "FAILED", "CANCELLED", "ABANDONED"],
  "node_reported_statuses": ["PENDING", "SKIPPED", "SCHEDULED", "DISPATCHED", "COMPLETED", "FAILED", "CANCELLED", "ABANDONED"],
  "attempt_transitions": [
    {"id": "N1", "from": [null], "event": "node_scheduled", "to": "SCHEDULED", "guards": ["G_NO_CUTOFF", "G_ATTEMPT_MONOTONIC"]},
    {"id": "N2", "from": ["SCHEDULED"], "event": "node_dispatched", "to": "DISPATCHED", "guards": ["G_NO_CUTOFF"]},
    {"id": "N3", "from": ["DISPATCHED"], "event": "node_result", "to": "COMPLETED", "guards": ["G_WITHIN_DEADLINE"]},
    {"id": "N4", "from": ["DISPATCHED"], "event": "node_failed", "to": "FAILED", "guards": ["G_WITHIN_DEADLINE"]},
    {"id": "N5", "from": ["SCHEDULED", "DISPATCHED"], "event": "node_cancelled", "to": "CANCELLED", "guards": []},
    {"id": "N6", "from": ["SCHEDULED", "DISPATCHED"], "event": "node_abandoned", "to": "ABANDONED", "guards": []},
    {"id": "N7", "from": ["FAILED"], "event": "node_scheduled", "to": "SCHEDULED", "guards": ["G_NO_CUTOFF", "G_ATTEMPT_MONOTONIC", "G_RETRY_PERMITTED"]},
    {"id": "N8", "from": ["ABANDONED"], "event": "node_reconciled", "to": "FAILED", "guards": ["G_PROVEN_NON_ACCEPTANCE"]}
  ],
  "guards": {
    "G_EXEC_SETTLED": "every STARTED non-adjudicator attempt settled AND every REQUIRED non-adjudicator node settled or skipped-under-cutoff; optional nodes may remain PENDING",
    "G_ADJ_SETTLED": "adjudicator settled (COMPLETED|FAILED|CANCELLED|ABANDONED) or skipped-under-cutoff",
    "G_CANCEL_FINAL": "cancelling flag set AND all attempts settled",
    "G_NO_CUTOFF": "forbidden after budget cutoff or cancel flag (ADR-1 I8)",
    "G_ATTEMPT_MONOTONIC": "attempt number = latest attempt + 1",
    "G_RETRY_PERMITTED": "prior attempt FAILED with retryable/corrective class AND attempts < max_attempts AND retry reserve > 0 AND remaining wall budget >= own deadline + sum of base deadlines of other pending required nodes",
    "G_WITHIN_DEADLINE": "dispatch-to-settle duration <= per-kind node deadline",
    "G_PROVEN_NON_ACCEPTANCE": "provider reconciliation proves the request was never accepted; reclassifies as transport_5xx, N7-eligible"
  },
  "failure_classes": {
    "retryable": ["transport_5xx", "rate_limit"],
    "corrective": ["malformed_output"],
    "non_retryable": ["policy_refusal", "timeout_unproven", "model_identity_mismatch", "stale_binding", "input_mutation"]
  },
  "node_kinds": ["probe", "finder", "adjudicator"],
  "node_event_phase_domain": {
    "probe": ["EXECUTING"],
    "finder": ["EXECUTING"],
    "adjudicator": ["ADJUDICATING"]
  },
  "event_identity": "(event_kind, event_id); conflict hash over canonical body {event_kind, node_id, attempt, payload}",
  "terminal_decision_order": [
    "corruption -> FAILED",
    "cancelling -> CANCELLED",
    "pre-execution block -> BLOCKED (via R0/R2/R4)",
    "any required node not COMPLETED -> INCOMPLETE",
    "HEAVY and any adjudicated finding UNVERIFIABLE with candidate_severity.level in {HIGH,CRITICAL} -> INCOMPLETE (V2-SM-08)",
    "else COMPLETED"
  ],
  "release_rules": {
    "LIGHT": "REPORT_ONLY",
    "HEAVY": "PROCEED iff terminal=COMPLETED and no adjudicated finding with candidate_severity.level >= HIGH and adjudication in {CONFIRMED,UNRESOLVED,UNVERIFIABLE}; else HOLD",
    "no_profile": "HOLD"
  },
  "severity_ladder": {
    "corruption_money_security": {"direct": "CRITICAL", "conditional": "HIGH", "unreachable": "LOW"},
    "wrong_result": {"direct": "HIGH", "conditional": "MEDIUM", "unreachable": "LOW"},
    "degraded_quality": {"direct": "MEDIUM", "conditional": "LOW", "unreachable": "INFO"}
  },
  "adjudications": ["CONFIRMED", "REJECTED", "UNRESOLVED", "UNVERIFIABLE"],
  "coverage_gap_rules": {
    "probe_or_finder_required_not_completed": "<node_id>:no_envelope",
    "adjudicator_required_not_completed": "<node_id>:no_adjudication"
  }
}
